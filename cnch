local function removeESP(player)
    local esp = ESPObjects[player]
    if esp then
        for _, d in pairs(esp) do
            pcall(function() if d then d:Remove() end end)
        end
        ESPObjects[player] = nil
    end
end

local function updateESP(player, esp)
    local cfg = getgenv().Config.ESP
    local char = player.Character
    if not char then
        for _, d in pairs(esp) do if d then d.Visible = false end end
        return
    end

    local humanoid = char:FindFirstChild("Humanoid")
    local head = char:FindFirstChild("Head")
    local root = char:FindFirstChild("HumanoidRootPart")

    if not humanoid or humanoid.Health <= 0 or not head or not root then
        for _, d in pairs(esp) do if d then d.Visible = false end end
        return
    end

    if cfg.TeamCheck and player.Team == LocalPlayer.Team then
        for _, d in pairs(esp) do if d then d.Visible = false end end
        return
    end

    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local dist = myRoot and (root.Position - myRoot.Position).Magnitude or 0
    if dist > cfg.MaxDistance then
        for _, d in pairs(esp) do if d then d.Visible = false end end
        return
    end

    local headPos, headOnScreen = Camera:WorldToViewportPoint(head.Position)
    local rootPos, rootOnScreen = Camera:WorldToViewportPoint(root.Position)
    if not headOnScreen and not rootOnScreen then
        for _, d in pairs(esp) do if d then d.Visible = false end end
        return
    end

    local screenY = headOnScreen and headPos.Y or rootPos.Y
    local screenX = rootOnScreen and rootPos.X or headPos.X
    local boxHeight = 100
    local boxWidth = 50
    local boxX = screenX - boxWidth / 2
    local boxY = screenY - boxHeight * 0.1

    if esp.HealthBarBG and esp.HealthBar and cfg.ShowHealthBar then
        local barWidth = 6
        local barHeight = boxHeight
        local hpRatio = humanoid.Health / humanoid.MaxHealth
        esp.HealthBarBG.Visible = true
        esp.HealthBarBG.Position = Vector2.new(boxX - barWidth - 4, boxY)
        esp.HealthBarBG.Size = Vector2.new(barWidth, barHeight)
        esp.HealthBar.Visible = true
        esp.HealthBar.Position = Vector2.new(boxX - barWidth - 4, boxY + barHeight * (1 - hpRatio))
        esp.HealthBar.Size = Vector2.new(barWidth, barHeight * hpRatio)
        if hpRatio > 0.5 then
            esp.HealthBar.Color = Color3.fromRGB(0, 255, 0)
        elseif hpRatio > 0.25 then
            esp.HealthBar.Color = Color3.fromRGB(255, 255, 0)
        else
            esp.HealthBar.Color = Color3.fromRGB(255, 0, 0)
        end
    elseif esp.HealthBarBG then
        esp.HealthBarBG.Visible = false
        if esp.HealthBar then esp.HealthBar.Visible = false end
    end

    if esp.Health and cfg.ShowHealth then
        esp.Health.Visible = true
        local hp = math.floor(humanoid.Health)
        esp.Health.Position = Vector2.new(screenX, boxY + boxHeight + 5)
        esp.Health.Text = hp .. " HP"
        local ratio = hp / humanoid.MaxHealth
        if ratio > 0.5 then
            esp.Health.Color = Color3.fromRGB(0, 255, 0)
        elseif ratio > 0.25 then
            esp.Health.Color = Color3.fromRGB(255, 255, 0)
        else
            esp.Health.Color = Color3.fromRGB(255, 0, 0)
        end
    elseif esp.Health then
        esp.Health.Visible = false
    end

    if esp.Distance and cfg.ShowDistance then
        esp.Distance.Visible = true
        esp.Distance.Position = Vector2.new(screenX, boxY + boxHeight + 18)
        esp.Distance.Text = math.floor(dist) .. "m"
    elseif esp.Distance then
        esp.Distance.Visible = false
    end

    if esp.Box and cfg.ShowBox then
        esp.Box.Visible = true
        esp.Box.Position = Vector2.new(boxX, boxY)
        esp.Box.Size = Vector2.new(boxWidth, boxHeight)
    elseif esp.Box then
        esp.Box.Visible = false
    end

    if esp.Name and cfg.ShowName then
        esp.Name.Visible = true
        esp.Name.Position = Vector2.new(screenX, boxY - 15)
        esp.Name.Text = player.Name
    elseif esp.Name then
        esp.Name.Visible = false
    end

    if esp.Weapon and cfg.ShowWeapon then
        esp.Weapon.Visible = true
        local toolName = ""
        for _, child in ipairs(char:GetChildren()) do
            if child:IsA("Tool") then
                toolName = child.Name
                break
            end
        end
        esp.Weapon.Position = Vector2.new(screenX, boxY + boxHeight + 30)
        esp.Weapon.Text = toolName
    elseif esp.Weapon then
        esp.Weapon.Visible = false
    end

    if esp.Tracer and cfg.ShowTracers then
        esp.Tracer.Visible = true
        esp.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
        esp.Tracer.To = Vector2.new(screenX, boxY)
    elseif esp.Tracer then
        esp.Tracer.Visible = false
    end

    if esp.HeadDot and cfg.ShowHeadDot and headOnScreen then
        esp.HeadDot.Visible = true
        esp.HeadDot.Position = Vector2.new(headPos.X, headPos.Y)
    elseif esp.HeadDot then
        esp.HeadDot.Visible = false
    end
end

-- ==================== 兼容 ESP ====================
local LegacyESPObjects = {}

local function createLegacyESP(player)
    if LegacyESPObjects[player] then return end
    local objs = {}

    pcall(function() objs.Box = Drawing.new("Square") end)
    pcall(function() objs.Tracer = Drawing.new("Line") end)
    pcall(function() objs.NameLabel = Drawing.new("Text") end)
    pcall(function() objs.HealthLabel = Drawing.new("Text") end)
    pcall(function() objs.DistanceLabel = Drawing.new("Text") end)
    pcall(function() objs.WeaponLabel = Drawing.new("Text") end)
    pcall(function() objs.HealthBarBG = Drawing.new("Square") end)
    pcall(function() objs.HealthBar = Drawing.new("Square") end)
    pcall(function() objs.HeadDot = Drawing.new("Circle") end)

    if objs.Box then
        objs.Box.Thickness = 2
        objs.Box.Color = Color3.fromRGB(255, 50, 50)
        objs.Box.Filled = false
        objs.Box.Visible = false
    end
    if objs.Tracer then
        objs.Tracer.Thickness = 1
        objs.Tracer.Color = Color3.fromRGB(255, 255, 255)
        objs.Tracer.Visible = false
    end
    if objs.NameLabel then
        objs.NameLabel.Size = 14
        objs.NameLabel.Center = true
        objs.NameLabel.Outline = true
        objs.NameLabel.Color = Color3.fromRGB(255, 255, 255)
        objs.NameLabel.Visible = false
    end
    if objs.HealthLabel then
        objs.HealthLabel.Size = 12
        objs.HealthLabel.Center = true
        objs.HealthLabel.Outline = true
        objs.HealthLabel.Visible = false
    end
    if objs.DistanceLabel then
        objs.DistanceLabel.Size = 12
        objs.DistanceLabel.Center = true
        objs.DistanceLabel.Outline = true
        objs.DistanceLabel.Color = Color3.fromRGB(180, 180, 180)
        objs.DistanceLabel.Visible = false
    end
    if objs.WeaponLabel then
        objs.WeaponLabel.Size = 11
        objs.WeaponLabel.Center = true
        objs.WeaponLabel.Outline = true
        objs.WeaponLabel.Color = Color3.fromRGB(255, 200, 100)
        objs.WeaponLabel.Visible = false
    end
    if objs.HealthBarBG then
        objs.HealthBarBG.Color = Color3.fromRGB(0, 0, 0)
        objs.HealthBarBG.Filled = true
        objs.HealthBarBG.Thickness = 1
        objs.HealthBarBG.Transparency = 0.8
        objs.HealthBarBG.Visible = false
    end
    if objs.HealthBar then
        objs.HealthBar.Color = Color3.fromRGB(0, 255, 0)
        objs.HealthBar.Filled = true
        objs.HealthBar.Thickness = 1
        objs.HealthBar.Transparency = 1
        objs.HealthBar.Visible = false
    end
    if objs.HeadDot then
        objs.HeadDot.Radius = 4
        objs.HeadDot.Filled = true
        objs.HeadDot.Color = Color3.fromRGB(255, 255, 0)
        objs.HeadDot.NumSides = 16
        objs.HeadDot.Visible = false
    end

    LegacyESPObjects[player] = objs
end

local function removeLegacyESP(player)
    local objs = LegacyESPObjects[player]
    if objs then
        for _, d in pairs(objs) do
            pcall(function() if d then d:Remove() end end)
        end
        LegacyESPObjects[player] = nil
    end
end

local function updateLegacyESP(player, objs)
    local cfg = getgenv().Config.ESP
    local char = player.Character
    if not char then
        for _, d in pairs(objs) do if d then d.Visible = false end end
        return
    end

    local humanoid = char:FindFirstChildOfClass("Humanoid")
    local head = char:FindFirstChild("Head")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not humanoid or humanoid.Health <= 0 or not head or not root then
        for _, d in pairs(objs) do if d then d.Visible = false end end
        return
    end

    if cfg.TeamCheck and player.Team == LocalPlayer.Team then
        for _, d in pairs(objs) do if d then d.Visible = false end end
        return
    end

    local camPos = Camera.CFrame.Position
    local dist = (root.Position - camPos).Magnitude
    if dist > cfg.MaxDistance then
        for _, d in pairs(objs) do if d then d.Visible = false end end
        return
    end

    local headPos, headOnScreen = Camera:WorldToViewportPoint(head.Position)
    local rootPos, rootOnScreen = Camera:WorldToViewportPoint(root.Position)
    if not headOnScreen and not rootOnScreen then
        for _, d in pairs(objs) do if d then d.Visible = false end end
        return
    end

    local legPos = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
    local screenY = headOnScreen and headPos.Y or rootPos.Y
    local screenX = rootOnScreen and rootPos.X or headPos.X
    local boxHeight = math.abs(headPos.Y - legPos.Y)
    local boxWidth = boxHeight * 0.6
    local boxX = screenX - boxWidth / 2
    local boxY = screenY - boxHeight * 0.1

    if objs.Box and cfg.ShowBox then
        objs.Box.Visible = true
        objs.Box.Size = Vector2.new(boxWidth, boxHeight)
        objs.Box.Position = Vector2.new(boxX, boxY)
    elseif objs.Box then
        objs.Box.Visible = false
    end

    if objs.Tracer and cfg.ShowTracers then
        objs.Tracer.Visible = true
        objs.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
        objs.Tracer.To = Vector2.new(screenX, screenY + boxHeight / 2)
    elseif objs.Tracer then
        objs.Tracer.Visible = false
    end

    if objs.NameLabel and cfg.ShowName then
        objs.NameLabel.Visible = true
        objs.NameLabel.Text = player.DisplayName or player.Name
        objs.NameLabel.Position = Vector2.new(screenX, boxY - 15)
    elseif objs.NameLabel then
        objs.NameLabel.Visible = false
    end

    if objs.HealthLabel and cfg.ShowHealth then
        objs.HealthLabel.Visible = true
        local hp = math.floor(humanoid.Health)
        objs.HealthLabel.Text = hp .. " HP"
        objs.HealthLabel.Position = Vector2.new(screenX, boxY + boxHeight + 5)
        local ratio = hp / humanoid.MaxHealth
        if ratio > 0.5 then
            objs.HealthLabel.Color = Color3.fromRGB(0, 255, 0)
        elseif ratio > 0.25 then
            objs.HealthLabel.Color = Color3.fromRGB(255, 255, 0)
        else
            objs.HealthLabel.Color = Color3.fromRGB(255, 0, 0)
        end
    elseif objs.HealthLabel then
        objs.HealthLabel.Visible = false
    end

    if objs.DistanceLabel and cfg.ShowDistance then
        objs.DistanceLabel.Visible = true
        objs.DistanceLabel.Text = math.floor(dist) .. "m"
        objs.DistanceLabel.Position = Vector2.new(screenX, boxY + boxHeight + 18)
    elseif objs.DistanceLabel then
        objs.DistanceLabel.Visible = false
    end

    if objs.WeaponLabel and cfg.ShowWeapon then
        local toolName = "无"
        for _, child in ipairs(char:GetChildren()) do
            if child:IsA("Tool") then
                toolName = child.Name
                break
            end
        end
        objs.WeaponLabel.Visible = true
        objs.WeaponLabel.Text = toolName
        objs.WeaponLabel.Position = Vector2.new(screenX, boxY + boxHeight + 30)
    elseif objs.WeaponLabel then
        objs.WeaponLabel.Visible = false
    end

    if objs.HealthBarBG and objs.HealthBar and cfg.ShowHealthBar then
        local barWidth = 6
        local barHeight = boxHeight
        local hpRatio = humanoid.Health / humanoid.MaxHealth
        objs.HealthBarBG.Visible = true
        objs.HealthBarBG.Position = Vector2.new(boxX - barWidth - 4, boxY)
        objs.HealthBarBG.Size = Vector2.new(barWidth, barHeight)
        objs.HealthBar.Visible = true
        objs.HealthBar.Position = Vector2.new(boxX - barWidth - 4, boxY + barHeight * (1 - hpRatio))
        objs.HealthBar.Size = Vector2.new(barWidth, barHeight * hpRatio)
        if hpRatio > 0.5 then
            objs.HealthBar.Color = Color3.fromRGB(0, 255, 0)
        elseif hpRatio > 0.25 then
            objs.HealthBar.Color = Color3.fromRGB(255, 255, 0)
        else
            objs.HealthBar.Color = Color3.fromRGB(255, 0, 0)
        end
    elseif objs.HealthBarBG then
        objs.HealthBarBG.Visible = false
        if objs.HealthBar then objs.HealthBar.Visible = false end
    end

    if objs.HeadDot and cfg.ShowHeadDot and headOnScreen then
        objs.HeadDot.Visible = true
        objs.HeadDot.Position = Vector2.new(headPos.X, headPos.Y)
    elseif objs.HeadDot then
        objs.HeadDot.Visible = false
    end
end

-- 初始化
for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        createESP(player)
        createLegacyESP(player)
    end
end

Players.PlayerAdded:Connect(function(player)
    if player ~= LocalPlayer then
        createESP(player)
        createLegacyESP(player)
    end
end)

Players.PlayerRemoving:Connect(function(player)
    removeESP(player)
    removeLegacyESP(player)
end)

-- ESP 更新
RunService.RenderStepped:Connect(function()
    local cfg = getgenv().Config.ESP
    if not cfg.Enabled then
        for _, esp in pairs(ESPObjects) do
            for _, d in pairs(esp) do if d then d.Visible = false end end
        end
        for _, objs in pairs(LegacyESPObjects) do
            for _, d in pairs(objs) do if d then d.Visible = false end end
        end
        return
    end

    if cfg.UseLegacy then
        for _, esp in pairs(ESPObjects) do
            for _, d in pairs(esp) do if d then d.Visible = false end end
        end
        for player, objs in pairs(LegacyESPObjects) do
            if player and player.Parent then
                updateLegacyESP(player, objs)
            end
        end
    else
        for _, objs in pairs(LegacyESPObjects) do
            for _, d in pairs(objs) do if d then d.Visible = false end end
        end
        for player, esp in pairs(ESPObjects) do
            if player and player.Parent then
                pcall(function() updateESP(player, esp) end)
            end
        end
    end
end)

